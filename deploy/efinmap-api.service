[Unit]
Description=efinmap FastAPI Service
After=network.target postgresql.service

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/efinmap
EnvironmentFile=/opt/efinmap/.env
ExecStart=/opt/efinmap/venv/bin/uvicorn api.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
