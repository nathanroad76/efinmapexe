# Copy this file to .env and replace ALL placeholder values before deploying.
# Never commit .env to git.

# PostgreSQL connection — replace CHANGE_ME_STRONG_PASSWORD with a real password
# (must match the password in deploy/init_db.sql when you create the user)
DATABASE_URL=postgresql://efinmap_user:CHANGE_ME_STRONG_PASSWORD@localhost:5432/efinmap

# Residential proxy for yfinance collectors. Format: host:port:username:password
# Leave blank to disable proxy (collectors will hit Yahoo directly).
PROXY_CONFIG=
